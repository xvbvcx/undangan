# --- Supabase ---
# https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- iPaymu ---
# https://my.ipaymu.com (production) / https://sandbox.ipaymu.com (sandbox)
IPAYMU_VA=
IPAYMU_API_KEY=
# "true" = pakai endpoint production, "false" = sandbox
IPAYMU_PRODUCTION=false
# Trust callback meskipun pengecekan transaction lookup gagal (development only)
IPAYMU_TRUST_CALLBACK=false
# Lewati pengecekan signature header (HANYA untuk debugging)
IPAYMU_SKIP_SIGNATURE_CHECK=false

# --- App ---
# Wajib URL absolut. Dipakai di OG metadata, callback URL, dll.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Harga premium dalam rupiah (default 299000)
PREMIUM_PRICE=299000
# Nomor WhatsApp admin (tanpa +). Dipakai di tombol "Custom manual via admin"
NEXT_PUBLIC_ADMIN_WHATSAPP=6281234567890
